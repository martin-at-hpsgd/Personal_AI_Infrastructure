<?xml version="1.0" encoding="UTF-8"?>
<!--
  com.lifeos.conveyor-watcher.plist.template — Source template. Install via:
    bun ~/.claude/LIFEOS/TOOLS/InstallConveyorWatcher.ts

  The installer reads $HOME at install time, substitutes {{HOME}} placeholders,
  writes the materialized plist to ~/Library/LaunchAgents/, and bootstraps it
  with launchctl. This template stays clean of principal-specific paths so it
  ships in the public LifeOS release.

  Behavior:
    Long-running Conveyor inbox watcher (KeepAlive daemon).
    Watches ~/Recordings/Inbox (override via CONVEYOR_INBOX) and registers
    dropped recordings in the content-pipeline ledger.
    Crash-loop rate-limited (ThrottleInterval 30s).
    stdout/stderr captured to MEMORY/STATE/com.lifeos.conveyor-watcher.log.
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.lifeos.conveyor-watcher</string>

  <key>ProgramArguments</key>
  <array>
    <string>{{BUN}}</string>
    <string>{{HOME}}/.claude/LIFEOS/TOOLS/Conveyor/Watcher.ts</string>
  </array>

  <key>RunAtLoad</key>
  <true/>

  <key>KeepAlive</key>
  <true/>

  <key>ThrottleInterval</key>
  <integer>30</integer>

  <key>StandardOutPath</key>
  <string>{{HOME}}/.claude/LIFEOS/MEMORY/STATE/com.lifeos.conveyor-watcher.log</string>

  <key>StandardErrorPath</key>
  <string>{{HOME}}/.claude/LIFEOS/MEMORY/STATE/com.lifeos.conveyor-watcher.log</string>

  <key>WorkingDirectory</key>
  <string>{{HOME}}/.claude</string>

  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>{{BUN_DIR}}:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
    <key>HOME</key>
    <string>{{HOME}}</string>
  </dict>
</dict>
</plist>
